's- studio-223
'use client';
import { useMemo, useState, useEffect } from 'react';
import Image from 'next/image';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Slider } from '@/components/ui/slider';
import { useToast } from '@/hooks/use-toast';
import { cn } from '@/lib/utils';
import { Calendar as CalendarIcon, ChevronLeft, ChevronRight } from 'lucide-react';
import { Calendar } from '@/components/ui/calendar';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogDescription } from '@/components/ui/dialog';
import { format, subDays, addDays, getDaysInMonth, startOfMonth } from 'date-fns';
import { ptBR } from 'date-fns/locale';
import { bowelMovementPhrases, selfCarePhrases } from '@/lib/dory-phrases';
const symptoms = [
    { emoji: '😣', label: 'Cólica' },
    { emoji: '🪨', label: 'Prisão de ventre' },
    { emoji: '💦', label: 'Inchaço' },
    { emoji: '🥶', label: 'Sensibilidade' },
    { emoji: '😴', label: 'Fadiga' },
    { emoji: '😖', label: 'Dor nas costas' },
    { emoji: '😵', label: 'Tontura' },
    { emoji: '🤢', label: 'Enjoos' },
    { emoji: '😰', label: 'Angústia' },
    { emoji: '❤️‍🔥', label: 'Dor no peito' },
    { emoji: '🤕', label: 'Dor de cabeça' },
    { emoji: '🤒', label: 'Febre leve' },
    { emoji: '😞', label: 'Desânimo' },
    { emoji: '😮‍💨', label: 'Falta de ar' },
    { emoji: '😫', label: 'Dor lombar' },
];
const painLevels = [
    { label: 'Sem dor', color: 'text-green-400' },
    { label: 'Desconforto leve', color: 'text-yellow-400' },
    { label: 'Cólica moderada', color: 'text-orange-400' },
    { label: 'Dor intensa', color: 'text-red-500' },
    { label: 'Crise', color: 'text-red-700' },
];
const BodyMap = ({ highlightedZone, onZoneClick }) => {
    return (<Card className="p-2 claymorphism bg-card/80 backdrop-blur-sm">
            <CardHeader>
                <CardTitle>Mapa do Corpo</CardTitle>
            </CardHeader>
            <CardContent className="relative">
                <Image src="/images/body-map.png" alt="Mapa do corpo feminino" width={500} height={700} className="w-full h-auto" useMap="#body-map" priority/>
                <map name="body-map">
                    <area shape="rect" coords="170,30,290,120" alt="Cabeça" onClick={() => onZoneClick('head')}/>
                    <area shape="rect" coords="150,121,310,250" alt="Peito" onClick={() => onZoneClick('chest')}/>
                    <area shape="rect" coords="160,251,300,350" alt="Abdômen" onClick={() => onZoneClick('abdomen')}/>
                    <area shape="rect" coords="160,351,300,420" alt="Pélvis/Útero" onClick={() => onZoneClick('pelvis')}/>
                    <area shape="rect" coords="150,121,310,420" alt="Costas" onClick={() => onZoneClick('back')}/>
                    <area shape="poly" coords="149,140,80,200,80,380,140,400" alt="Braço Esquerdo" onClick={() => onZoneClick('left-arm')}/>
                    <area shape="poly" coords="311,140,380,200,380,380,320,400" alt="Braço Direito" onClick={() => onZoneClick('right-arm')}/>
                    <area shape="rect" coords="150,421,310,650" alt="Pernas" onClick={() => onZoneClick('legs')}/>
                </map>
                {highlightedZone && (<div className={cn("absolute w-full h-full top-0 left-0 bg-red-500/40 animate-pulse pointer-events-none", "rounded-2xl", {
            'clip-path-head': highlightedZone === 'head',
            'clip-path-chest': highlightedZone === 'chest',
            'clip-path-abdomen': highlightedZone === 'abdomen',
            'clip-path-pelvis': highlightedZone === 'pelvis',
            'clip-path-back': highlightedZone === 'back',
            'clip-path-left-arm': highlightedZone === 'left-arm',
            'clip-path-right-arm': highlightedZone === 'right-arm',
            'clip-path-legs': highlightedZone === 'legs',
        })}/>)}
            </CardContent>
        </Card>);
};
export default function DiarioDeDorPage() {
    const { toast } = useToast();
    const [selectedSymptoms, setSelectedSymptoms] = useState([]);
    const [painLevel, setPainLevel] = useState(0);
    const [highlightedZone, setHighlightedZone] = useState(null);
    const [dailyLogs, setDailyLogs] = useState({});
    const [isCalendarOpen, setIsCalendarOpen] = useState(false);
    const [currentMonth, setCurrentMonth] = useState(new Date());
    const today = new Date();
    const yesterday = subDays(today, 1);
    const dayBefore = subDays(today, 2);
    const handleSymptomToggle = (label) => {
        const newSymptoms = selectedSymptoms.includes(label)
            ? selectedSymptoms.filter(s => s !== label)
            : [...selectedSymptoms, label];
        setSelectedSymptoms(newSymptoms);
        const logKey = format(today, 'yyyy-MM-dd');
        setDailyLogs(prev => ({ ...prev, [logKey]: { ...prev[logKey], symptoms: newSymptoms } }));
        toast({ title: 'Seu corpo tá falando… e eu tô ouvindo. 💙' });
    };
    const handlePainLevelChange = (value) => {
        const level = value[0];
        setPainLevel(level);
        toast({
            title: 'Registrando seu nível de dor...',
            description: selfCarePhrases[Math.floor(Math.random() * selfCarePhrases.length)],
        });
        const logKey = format(today, 'yyyy-MM-dd');
        setDailyLogs(prev => ({ ...prev, [logKey]: { ...prev[logKey], pain: level } }));
    };
    const handleZoneClick = (zone) => {
        setHighlightedZone(zone);
        toast({ title: 'Isso ajuda a identificar padrões. Continue assim!' });
        setTimeout(() => setHighlightedZone(null), 1000); // Pulse for 1 sec
    };
    const handleBowelMovement = (date) => {
        const logKey = format(date, 'yyyy-MM-dd');
        const newLog = { ...dailyLogs[logKey], bowel: !dailyLogs[logKey]?.bowel };
        setDailyLogs(prev => ({ ...prev, [logKey]: newLog }));
        if (newLog.bowel) {
            toast({ title: bowelMovementPhrases[Math.floor(Math.random() * bowelMovementPhrases.length)], duration: 3000 });
        }
    };
    const resetToday = () => {
        setSelectedSymptoms([]);
        setPainLevel(0);
        const logKey = format(today, 'yyyy-MM-dd');
        setDailyLogs(prev => ({ ...prev, [logKey]: {} }));
        toast({ title: 'Tudo limpo! Vamos recomeçar?' });
    };
    const calendarDatesWithLogs = Object.keys(dailyLogs).filter(key => Object.keys(dailyLogs[key]).length > 0).map(key => new Date(key));
    return (<div className="p-4 space-y-8 md:p-8">
            <header className="text-center">
                <h1 className="text-3xl font-bold tracking-wider">❤️‍🩹 Diário de Dor</h1>
                <p className="text-muted-foreground">Tem alguma coisa doendo hoje?</p>
            </header>

            <Card className="claymorphism bg-card/80 backdrop-blur-sm">
                <CardHeader>
                    <CardTitle>Sintomas de Hoje</CardTitle>
                </CardHeader>
                <CardContent className="grid grid-cols-2 gap-2">
                    {symptoms.map(symptom => (<Button key={symptom.label} variant={selectedSymptoms.includes(symptom.label) ? 'default' : 'outline'} onClick={() => handleSymptomToggle(symptom.label)} className="gap-2 justify-start claymorphism">
                            <span>{symptom.emoji}</span>
                            <span className="text-xs">{symptom.label}</span>
                        </Button>))}
                </CardContent>
            </Card>
            
            <Card className="claymorphism bg-card/80 backdrop-blur-sm">
                <CardHeader>
                    <CardTitle>Nível de Dor</CardTitle>
                    <CardDescription className={cn("font-bold transition-colors", painLevels[painLevel].color)}>
                        {painLevels[painLevel].label}
                    </CardDescription>
                </CardHeader>
                <CardContent>
                    <Slider value={[painLevel]} onValueChange={handlePainLevelChange} max={4} step={1}/>
                </CardContent>
            </Card>

            <BodyMap highlightedZone={highlightedZone} onZoneClick={handleZoneClick}/>

            <Card className="claymorphism bg-card/80 backdrop-blur-sm">
                <CardHeader>
                    <CardTitle>Sessão do Descarrego</CardTitle>
                </CardHeader>
                <CardContent className="space-y-4">
                    <div className="grid grid-cols-3 gap-2">
                        {[dayBefore, yesterday, today].map(date => {
            const logKey = format(date, 'yyyy-MM-dd');
            const hasBowelMovement = dailyLogs[logKey]?.bowel;
            return (<Card key={date.toString()} onClick={() => handleBowelMovement(date)} className={cn("text-center p-3 cursor-pointer claymorphism transition-all", hasBowelMovement ? 'bg-primary/20 border-primary' : 'bg-background/50')}>
                                    <p className="text-sm font-semibold">{format(date, 'E', { locale: ptBR })}</p>
                                    <p className="my-1 text-3xl">{hasBowelMovement ? '💩' : '🤔'}</p>
                                    <p className="font-bold">{format(date, 'd')}</p>
                                </Card>);
        })}
                    </div>
                    <Button variant="outline" className="w-full" onClick={() => setIsCalendarOpen(true)}>
                        <CalendarIcon className="w-4 h-4 mr-2"/> Ver o mês
                    </Button>
                </CardContent>
            </Card>
            
            <Button variant="destructive" onClick={resetToday} className="w-full claymorphism">Resetar Dia</Button>

            <Dialog open={isCalendarOpen} onOpenChange={setIsCalendarOpen}>
                <DialogContent className="max-w-sm claymorphism">
                    <DialogHeader>
                        <DialogTitle>Histórico de {format(currentMonth, 'MMMM', { locale: ptBR })}</DialogTitle>
                    </DialogHeader>
                    <Calendar mode="single" month={currentMonth} onMonthChange={setCurrentMonth} selected={undefined} disabled={(date) => date > new Date()} locale={ptBR} modifiers={{ logged: calendarDatesWithLogs }} modifiersStyles={{ logged: { fontWeight: 'bold' } }} components={{
            DayContent: ({ date }) => {
                const log = dailyLogs[format(date, 'yyyy-MM-dd')];
                const painEmoji = log?.pain !== undefined ? ['😊', '😕', '😟', '😣', '🥵'][log.pain] : '';
                return (<div className="relative flex flex-col items-center justify-center w-full h-full">
                                        <span>{date.getDate()}</span>
                                        <div className="absolute bottom-0 flex text-xs">
                                            {log?.bowel && '💩'}
                                            {painEmoji && <span>{painEmoji}</span>}
                                        </div>
                                    </div>);
            },
        }}/>
                </DialogContent>
            </Dialog>

            <style jsx global>{`
                .clip-path-head { clip-path: ellipse(25% 15% at 50% 15%); }
                .clip-path-chest { clip-path: polygon(30% 25%, 70% 25%, 70% 45%, 30% 45%); }
                .clip-path-abdomen { clip-path: polygon(32% 45%, 68% 45%, 65% 60%, 35% 60%); }
                .clip-path-pelvis { clip-path: polygon(35% 60%, 65% 60%, 60% 70%, 40% 70%); }
                .clip-path-back { clip-path: polygon(30% 25%, 70% 25%, 70% 70%, 30% 70%); }
                .clip-path-left-arm { clip-path: polygon(0% 20%, 30% 25%, 30% 65%, 0% 70%); }
                .clip-path-right-arm { clip-path: polygon(100% 20%, 70% 25%, 70% 65%, 100% 70%); }
                .clip-path-legs { clip-path: polygon(25% 70%, 75% 70%, 75% 100%, 25% 100%); }
                
                @keyframes pulse {
                    0%, 100% { opacity: 0.4; }
                    50% { opacity: 0.7; }
                }
                .animate-pulse {
                    animation: pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
                }
            `}</style>
        </div>);
}
